String normalizePath(String name) {
  name.trim();
  if (name.length() == 0) return "/";
  if (!name.startsWith("/")) name = "/" + name;
  return name;
}

String fileNameOnly(String path) {
  path = normalizePath(path);
  int idx = path.lastIndexOf('/');
  if (idx >= 0) return path.substring(idx + 1);
  return path;
}

String jsonEscape(String s) {
  s.replace("\\", "\\\\");
  s.replace("\"", "\\\"");
  return s;
}

bool isLeapYear(int year) {
  if (year % 400 == 0) return true;
  if (year % 100 == 0) return false;
  return (year % 4 == 0);
}

bool isValidDateTimeParts(int year, int month, int day, int hour, int minute, int second) {
  if (year < 2020 || year > 2099) return false;
  if (month < 1 || month > 12) return false;
  if (hour < 0 || hour > 23) return false;
  if (minute < 0 || minute > 59) return false;
  if (second < 0 || second > 59) return false;

  int daysInMonth;
  switch (month) {
    case 1: case 3: case 5: case 7: case 8: case 10: case 12: daysInMonth = 31; break;
    case 4: case 6: case 9: case 11: daysInMonth = 30; break;
    case 2: daysInMonth = isLeapYear(year) ? 29 : 28; break;
    default: return false;
  }

  if (day < 1 || day > daysInMonth) return false;
  return true;
}

String makeFileName() {
  if (rtcAvailable) {
    DateTime now = rtc.now();
    String base = "/" + formatFileStamp(now);
    String name = base + ".wav";

    if (!SD.exists(name)) return name;

    int suffix = 1;
    while (true) {
      name = base + "_" + String(suffix) + ".wav";
      if (!SD.exists(name)) return name;
      suffix++;
    }
  }

  static int index = 0;
  String name;
  do {
    name = "/rec_" + String(index++) + ".wav";
  } while (SD.exists(name));
  return name;
}

int makeDayKey(const DateTime& dt) {
  return dt.year() * 10000 + dt.month() * 100 + dt.day();
}

// =====================================================
// PREFERENCES
// =====================================================
void saveSettings() {
  prefs.begin(PREF_NS, false);

  prefs.putBool(PREF_AP_ENABLED, scheduledAPEnabled);
  if (scheduledAPEnabled) {
    prefs.putULong(PREF_AP_TS, scheduledAPTime.unixtime());
  } else {
    prefs.remove(PREF_AP_TS);
  }

  prefs.putBool(PREF_DAILY_EN, dailyAPEnabled);
  prefs.putInt(PREF_DAILY_H, dailyAPHour);
  prefs.putInt(PREF_DAILY_M, dailyAPMinute);
  prefs.putInt(PREF_AP_TIMEOUT, apTimeoutMinutes);

  prefs.putInt(PREF_NOISE_THR, noiseThreshold);
  prefs.putInt(PREF_SND_CONF, soundConfirmCount);
  prefs.putInt(PREF_SND_WIN, soundWindowSize);

  prefs.end();

  Serial.println("[PREF] settings saved");
}

void loadSettings() {
  prefs.begin(PREF_NS, true);

  scheduledAPEnabled = prefs.getBool(PREF_AP_ENABLED, false);
  if (scheduledAPEnabled) {
    uint32_t ts = prefs.getULong(PREF_AP_TS, 0);
    if (ts > 0) {
      scheduledAPTime = DateTime(ts);
    } else {
      scheduledAPEnabled = false;
    }
  }

  dailyAPEnabled = prefs.getBool(PREF_DAILY_EN, false);
  dailyAPHour = prefs.getInt(PREF_DAILY_H, 21);
  dailyAPMinute = prefs.getInt(PREF_DAILY_M, 0);
  apTimeoutMinutes = prefs.getInt(PREF_AP_TIMEOUT, 10);

  noiseThreshold = prefs.getInt(PREF_NOISE_THR, 3500);
  soundConfirmCount = prefs.getInt(PREF_SND_CONF, 3);
  soundWindowSize = prefs.getInt(PREF_SND_WIN, 5);

  prefs.end();

  if (dailyAPHour < 0 || dailyAPHour > 23) dailyAPHour = 21;
  if (dailyAPMinute < 0 || dailyAPMinute > 59) dailyAPMinute = 0;
  if (apTimeoutMinutes < 1 || apTimeoutMinutes > 1440) apTimeoutMinutes = 10;

  if (noiseThreshold < 100) noiseThreshold = 100;
  if (noiseThreshold > 30000) noiseThreshold = 30000;

  if (soundConfirmCount < 1) soundConfirmCount = 1;
  if (soundConfirmCount > 10) soundConfirmCount = 10;

  if (soundWindowSize < 1) soundWindowSize = 1;
  if (soundWindowSize > MAX_SOUND_WINDOW_SIZE) soundWindowSize = MAX_SOUND_WINDOW_SIZE;

  scheduledAPAlreadyTriggered = false;
  Serial.println("[PREF] settings loaded");
}

// =====================================================
// WAV HEADER
// =====================================================
void writeWavHeader(File file, uint32_t dataSize) {
  uint32_t fileSize = dataSize + 36;
  uint16_t audioFormat = 1;
  uint16_t numChannels = CHANNELS;
  uint32_t sampleRate = SAMPLE_RATE;
  uint16_t bitsPerSample = BITS_PER_SAMPLE;
  uint32_t byteRate = sampleRate * numChannels * bitsPerSample / 8;
  uint16_t blockAlign = numChannels * bitsPerSample / 8;

  file.seek(0);

  file.write((const uint8_t*)"RIFF", 4);
  file.write((uint8_t*)&fileSize, 4);
  file.write((const uint8_t*)"WAVE", 4);

  file.write((const uint8_t*)"fmt ", 4);
  uint32_t subchunk1Size = 16;
  file.write((uint8_t*)&subchunk1Size, 4);
  file.write((uint8_t*)&audioFormat, 2);
  file.write((uint8_t*)&numChannels, 2);
  file.write((uint8_t*)&sampleRate, 4);
  file.write((uint8_t*)&byteRate, 4);
  file.write((uint8_t*)&blockAlign, 2);
  file.write((uint8_t*)&bitsPerSample, 2);

  file.write((const uint8_t*)"data", 4);
  file.write((uint8_t*)&dataSize, 4);
}

void createEmptyWavHeader(File file) {
  for (int i = 0; i < 44; i++) {
    file.write((uint8_t)0);
  }
}

// =====================================================
// I2S
// =====================================================
void setupI2S() {
  Serial.println("[I2S] init...");

  i2s_config_t i2s_config = {
    .mode = (i2s_mode_t)(I2S_MODE_MASTER | I2S_MODE_RX),
    .sample_rate = SAMPLE_RATE,
    .bits_per_sample = I2S_BITS_PER_SAMPLE_32BIT,
    .channel_format = I2S_CHANNEL_FMT_ONLY_LEFT,
    .communication_format = I2S_COMM_FORMAT_STAND_I2S,
    .intr_alloc_flags = ESP_INTR_FLAG_LEVEL1,
    .dma_buf_count = 8,
    .dma_buf_len = 256,
    .use_apll = false,
    .tx_desc_auto_clear = false,
    .fixed_mclk = 0
  };

  i2s_pin_config_t pin_config = {
    .bck_io_num = I2S_SCK,
    .ws_io_num = I2S_WS,
    .data_out_num = I2S_PIN_NO_CHANGE,
    .data_in_num = I2S_SD
  };

  esp_err_t err1 = i2s_driver_install(I2S_NUM_0, &i2s_config, 0, NULL);
  esp_err_t err2 = i2s_set_pin(I2S_NUM_0, &pin_config);

  if (err1 != ESP_OK || err2 != ESP_OK) {
    Serial.printf("[I2S] ERROR driver=%d pin=%d\n", err1, err2);
  } else {
    i2s_zero_dma_buffer(I2S_NUM_0);
    Serial.println("[I2S] ready");
  }
}

// =====================================================
// RTC
// =====================================================
bool setupRTC() {
  Serial.println("[RTC] init...");

  Wire.begin(RTC_SDA, RTC_SCL);

  if (!rtc.begin()) {
    Serial.println("[RTC] ERROR DS3231 not found");
    return false;
  }

  if (rtc.lostPower()) {
    Serial.println("[RTC] WARNING lost power, time may be invalid");
  }

  DateTime now = rtc.now();
  Serial.printf("[RTC] now: %s\n", formatDateTime(now).c_str());
  Serial.println("[RTC] ready");
  return true;
}

// =====================================================
// SD
// =====================================================
bool setupSD() {
  Serial.println("[SD] init SPI...");
  spiSD.begin(SD_SCK, SD_MISO, SD_MOSI, SD_CS);

  if (!SD.begin(SD_CS, spiSD)) {
    Serial.println("[SD] ERROR mount failed");
    return false;
  }

  uint8_t cardType = SD.cardType();
  if (cardType == CARD_NONE) {
    Serial.println("[SD] ERROR no card");
    return false;
  }

  Serial.print("[SD] card type: ");
  if (cardType == CARD_MMC) Serial.println("MMC");
  else if (cardType == CARD_SD) Serial.println("SDSC");
  else if (cardType == CARD_SDHC) Serial.println("SDHC");
  else Serial.println("UNKNOWN");

  uint64_t cardSize = SD.cardSize() / (1024 * 1024);
  Serial.printf("[SD] size: %llu MB\n", cardSize);

  Serial.println("[SD] ready");
  return true;
}

// =====================================================
// AUDIO LEVEL
// =====================================================
int32_t getAudioLevel() {
  int32_t samples[BUFFER_SAMPLES];
  size_t bytesRead = 0;

  i2s_read(I2S_NUM_0, samples, sizeof(samples), &bytesRead, portMAX_DELAY);

  int count = bytesRead / 4;
  if (count <= 0) return 0;

  uint64_t sum = 0;
  int32_t peak = 0;

  for (int i = 0; i < count; i++) {
    int32_t s = samples[i] >> 14;
    if (s < 0) s = -s;
    sum += s;
    if (s > peak) peak = s;
  }

  int32_t avg = sum / count;
  int32_t score = avg + peak / 4;
  return score;
}

int getSmoothedAudioLevel() {
  int level = getAudioLevel();

  if (soundWindowSize < 1) soundWindowSize = 1;
  if (soundWindowSize > MAX_SOUND_WINDOW_SIZE) soundWindowSize = MAX_SOUND_WINDOW_SIZE;

  soundWindow[soundWindowIndex] = level;
  soundWindowIndex++;

  if (soundWindowIndex >= soundWindowSize) {
    soundWindowIndex = 0;
    soundWindowFilled = true;
  }

  int count = soundWindowFilled ? soundWindowSize : soundWindowIndex;
  if (count <= 0) return level;

  long sum = 0;
  int peak = 0;
  for (int i = 0; i < count; i++) {
    sum += soundWindow[i];
    if (soundWindow[i] > peak) peak = soundWindow[i];
  }

  int avg = sum / count;
  int smoothScore = (avg * 3 + peak) / 4;
  return smoothScore;
}

// =====================================================
// RECORD WAV
// =====================================================
bool recordWav(const char* filename, uint16_t seconds) {
  Serial.println();
  Serial.println("################ RECORD START ################");
  Serial.printf("[REC] file: %s\n", filename);
  Serial.printf("[REC] duration: %u sec\n", seconds);

  currentMode = MODE_RECORDING;
  isRecording = true;

  File file = SD.open(filename, FILE_WRITE);
  if (!file) {
    Serial.println("[REC] ERROR open file for write");
    isRecording = false;
    currentMode = MODE_MONITOR;
    return false;
  }

  createEmptyWavHeader(file);

  uint32_t totalSamples = SAMPLE_RATE * seconds;
  uint32_t writtenDataBytes = 0;

  int32_t i2sBuffer[BUFFER_SAMPLES];
  int16_t pcmBuffer[BUFFER_SAMPLES];

  unsigned long lastRecLog = 0;
  unsigned long startMs = millis();

  while (totalSamples > 0) {
    if (stopMonitoring || currentMode == MODE_WIFI || requestResumeMonitoring) {
      Serial.println("[REC] interrupted by mode switch");
      break;
    }

    size_t bytesRead = 0;
    i2s_read(I2S_NUM_0, i2sBuffer, sizeof(i2sBuffer), &bytesRead, portMAX_DELAY);

    int samplesRead = bytesRead / 4;
    if (samplesRead <= 0) continue;

    if ((uint32_t)samplesRead > totalSamples) {
      samplesRead = totalSamples;
    }

    for (int i = 0; i < samplesRead; i++) {
      int32_t sample = i2sBuffer[i] >> 14;
      if (sample > 32767) sample = 32767;
      if (sample < -32768) sample = -32768;
      pcmBuffer[i] = (int16_t)sample;
    }

    size_t written = file.write((uint8_t*)pcmBuffer, samplesRead * sizeof(int16_t));
    writtenDataBytes += written;
    totalSamples -= samplesRead;

    if (millis() - lastRecLog > 1000) {
      lastRecLog = millis();
      unsigned long elapsed = (millis() - startMs) / 1000;
      Serial.printf("[REC] elapsed=%lus written=%u bytes remainingSamples=%u\n",
                    elapsed, writtenDataBytes, totalSamples);
    }
  }

  writeWavHeader(file, writtenDataBytes);
  file.close();

  isRecording = false;
  soundTriggerCount = 0;
  soundWindowIndex = 0;
  soundWindowFilled = false;

  if (currentMode != MODE_WIFI) {
    currentMode = MODE_MONITOR;
  }

  Serial.printf("[REC] finish bytes=%u\n", writtenDataBytes);
  Serial.println("################ RECORD END ##################");
  Serial.println();

  return true;
}

// =====================================================
// TOUCH
// =====================================================
bool checkTouchTriggered() {
  int val = touchRead(TOUCH_PIN);
  Serial.printf("[TOUCH] raw=%d | trigger if < %d\n", val, touchThreshold);

  if (val < touchThreshold) {
    touchTriggerCount++;
    Serial.printf("[TOUCH] touch detected %d/%d\n", touchTriggerCount, touchConfirmCount);
  } else {
    if (touchTriggerCount > 0) {
      Serial.println("[TOUCH] released, counter reset");
    }
    touchTriggerCount = 0;
  }

  return (touchTriggerCount >= touchConfirmCount);
}

// =====================================================
// SCHEDULED AP
// =====================================================
bool checkOneShotAPTrigger() {
  if (!rtcAvailable) return false;
  if (!scheduledAPEnabled) return false;
  if (scheduledAPAlreadyTriggered) return false;

  DateTime now = rtc.now();

  if (now.unixtime() >= scheduledAPTime.unixtime()) {
    Serial.println("[RTC] one-shot AP trigger fired");
    scheduledAPAlreadyTriggered = true;
    scheduledAPEnabled = false;
    saveSettings();
    return true;
  }

  return false;
}

bool checkDailyAPTrigger() {
  if (!rtcAvailable) return false;
  if (!dailyAPEnabled) return false;

  DateTime now = rtc.now();
  int todayKey = makeDayKey(now);

  if (lastDailyTriggerDayKey == todayKey) {
    return false;
  }

  if (now.hour() == dailyAPHour && now.minute() == dailyAPMinute) {
    lastDailyTriggerDayKey = todayKey;
    Serial.printf("[RTC] daily AP trigger fired at %02d:%02d\n", dailyAPHour, dailyAPMinute);
    return true;
  }

  return false;
}

// =====================================================
// SORTED FILE LIST
// =====================================================
int collectSortedWavFiles(FileItem *items, int maxItems) {
  File root = SD.open("/");
  if (!root) return 0;

  int count = 0;

  while (true) {
    File file = root.openNextFile();
    if (!file) break;

    if (!file.isDirectory()) {
      String fullName = normalizePath(String(file.name()));
      if (isWavFileName(fullName)) {
        if (count < maxItems) {
          items[count].name = fullName;
          items[count].size = file.size();
          count++;
        }
      }
    }
    file.close();
  }
  root.close();

  for (int i = 0; i < count - 1; i++) {
    for (int j = i + 1; j < count; j++) {
      if (items[j].name < items[i].name) {
        FileItem tmp = items[i];
        items[i] = items[j];
        items[j] = tmp;
      }
    }
  }

  return count;
}

