String modeToString(SystemMode mode) {
  switch (mode) {
    case MODE_MONITOR: return "MONITOR";
    case MODE_RECORDING: return "RECORDING";
    case MODE_WIFI: return "WIFI";
    default: return "UNKNOWN";
  }
}

String twoDigits(int v) {
  if (v < 10) return "0" + String(v);
  return String(v);
}

String formatDateTime(const DateTime& dt) {
  String s = "";
  s += String(dt.year());
  s += "-";
  s += twoDigits(dt.month());
  s += "-";
  s += twoDigits(dt.day());
  s += " ";
  s += twoDigits(dt.hour());
  s += ":";
  s += twoDigits(dt.minute());
  s += ":";
  s += twoDigits(dt.second());
  return s;
}

String formatFileStamp(const DateTime& dt) {
  String s = "";
  s += twoDigits(dt.day());
  s += "_";
  s += twoDigits(dt.month());
  s += "_";
  s += twoDigits(dt.hour());
  s += "_";
  s += twoDigits(dt.minute());
  return s;
}

String formatDailyTime() {
  if (!dailyAPEnabled) return "disabled";
  return twoDigits(dailyAPHour) + ":" + twoDigits(dailyAPMinute);
}

bool isWavFileName(const String& path) {
  String s = path;
  s.toLowerCase();
  return s.endsWith(".wav");
}

