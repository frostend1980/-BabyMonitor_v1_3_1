// =====================================================
// WEB HELPERS
// =====================================================
bool openFileForReadByArg(const String& argName, File &file, String &path) {
  if (!server.hasArg(argName)) {
    Serial.printf("[WEB] missing arg: %s\n", argName.c_str());
    return false;
  }

  path = normalizePath(server.arg(argName));
  if (!isWavFileName(path)) {
    Serial.printf("[WEB] not wav: %s\n", path.c_str());
    return false;
  }

  Serial.printf("[WEB] requested path: %s\n", path.c_str());

  if (!SD.exists(path)) {
    Serial.printf("[WEB] file not found: %s\n", path.c_str());
    return false;
  }

  file = SD.open(path, FILE_READ);
  if (!file) {
    Serial.printf("[WEB] open failed: %s\n", path.c_str());
    return false;
  }

  Serial.printf("[WEB] open ok: %s size=%u\n", path.c_str(), (uint32_t)file.size());
  return true;
}

// =====================================================
// WEB HANDLERS
// =====================================================
void handleRoot() {
  server.send(200, "text/html; charset=utf-8", htmlPage());
}

void handleStatus() {
  String rtcNow = rtcAvailable ? formatDateTime(rtc.now()) : "RTC not available";
  String nextAP = scheduledAPEnabled ? formatDateTime(scheduledAPTime) : "not set";

  String json = "{";
  json += "\"fw\":\"" + String(FW_VERSION) + "\",";
  json += "\"mode\":\"" + modeToString(currentMode) + "\",";
  json += "\"rtcAvailable\":" + String(rtcAvailable ? "true" : "false") + ",";
  json += "\"rtcNow\":\"" + jsonEscape(rtcNow) + "\",";
  json += "\"nextAp\":\"" + jsonEscape(nextAP) + "\",";
  json += "\"dailyAp\":\"" + jsonEscape(formatDailyTime()) + "\",";
  json += "\"apTimeoutMinutes\":" + String(apTimeoutMinutes) + ",";
  json += "\"noiseThreshold\":" + String(noiseThreshold) + ",";
  json += "\"soundConfirmCount\":" + String(soundConfirmCount) + ",";
  json += "\"soundWindowSize\":" + String(soundWindowSize) + ",";
  json += "\"scheduledAPEnabled\":" + String(scheduledAPEnabled ? "true" : "false") + ",";
  json += "\"dailyAPEnabled\":" + String(dailyAPEnabled ? "true" : "false");
  json += "}";

  server.send(200, "application/json; charset=utf-8", json);
}

void handleSetRTC() {
  if (!rtcAvailable) {
    server.send(500, "text/plain; charset=utf-8", "RTC not available");
    return;
  }

  if (!(server.hasArg("year") && server.hasArg("month") && server.hasArg("day") &&
        server.hasArg("hour") && server.hasArg("minute") && server.hasArg("second"))) {
    server.send(400, "text/plain; charset=utf-8", "Missing datetime args");
    return;
  }

  int year = server.arg("year").toInt();
  int month = server.arg("month").toInt();
  int day = server.arg("day").toInt();
  int hour = server.arg("hour").toInt();
  int minute = server.arg("minute").toInt();
  int second = server.arg("second").toInt();

  if (!isValidDateTimeParts(year, month, day, hour, minute, second)) {
    server.send(400, "text/plain; charset=utf-8", "Invalid datetime");
    return;
  }

  DateTime dt(year, month, day, hour, minute, second);
  rtc.adjust(dt);

  server.send(200, "text/plain; charset=utf-8", "RTC updated: " + formatDateTime(dt));
}

void handleSetAP() {
  if (!rtcAvailable) {
    server.send(500, "text/plain; charset=utf-8", "RTC not available");
    return;
  }

  if (!(server.hasArg("year") && server.hasArg("month") && server.hasArg("day") &&
        server.hasArg("hour") && server.hasArg("minute") && server.hasArg("second"))) {
    server.send(400, "text/plain; charset=utf-8", "Missing datetime args");
    return;
  }

  int year = server.arg("year").toInt();
  int month = server.arg("month").toInt();
  int day = server.arg("day").toInt();
  int hour = server.arg("hour").toInt();
  int minute = server.arg("minute").toInt();
  int second = server.arg("second").toInt();

  if (!isValidDateTimeParts(year, month, day, hour, minute, second)) {
    server.send(400, "text/plain; charset=utf-8", "Invalid datetime");
    return;
  }

  DateTime dt(year, month, day, hour, minute, second);

  if (rtcAvailable && dt.unixtime() <= rtc.now().unixtime()) {
    server.send(400, "text/plain; charset=utf-8", "AP time must be in the future");
    return;
  }

  scheduledAPTime = dt;
  scheduledAPEnabled = true;
  scheduledAPAlreadyTriggered = false;
  saveSettings();

  server.send(200, "text/plain; charset=utf-8", "One-shot AP set: " + formatDateTime(dt));
}

void handleClearAP() {
  scheduledAPEnabled = false;
  scheduledAPAlreadyTriggered = false;
  saveSettings();
  server.send(200, "text/plain; charset=utf-8", "One-shot AP cleared");
}

void handleSetDaily() {
  if (!(server.hasArg("hour") && server.hasArg("minute"))) {
    server.send(400, "text/plain; charset=utf-8", "Missing args");
    return;
  }

  int h = server.arg("hour").toInt();
  int m = server.arg("minute").toInt();

  if (h < 0 || h > 23 || m < 0 || m > 59) {
    server.send(400, "text/plain; charset=utf-8", "Invalid time");
    return;
  }

  dailyAPHour = h;
  dailyAPMinute = m;
  dailyAPEnabled = true;
  saveSettings();

  server.send(200, "text/plain; charset=utf-8", "Daily AP set: " + formatDailyTime());
}

void handleClearDaily() {
  dailyAPEnabled = false;
  saveSettings();
  server.send(200, "text/plain; charset=utf-8", "Daily AP disabled");
}

void handleSetAPTimeout() {
  if (!server.hasArg("minutes")) {
    server.send(400, "text/plain; charset=utf-8", "Missing minutes");
    return;
  }

  int minutes = server.arg("minutes").toInt();
  if (minutes < 1 || minutes > 1440) {
    server.send(400, "text/plain; charset=utf-8", "Minutes must be 1..1440");
    return;
  }

  apTimeoutMinutes = minutes;
  saveSettings();

  server.send(200, "text/plain; charset=utf-8", "AP timeout set: " + String(apTimeoutMinutes) + " min");
}

void handleSetSound() {
  if (!(server.hasArg("noise") && server.hasArg("confirm") && server.hasArg("window"))) {
    server.send(400, "text/plain; charset=utf-8", "Missing sound args");
    return;
  }

  int newNoise = server.arg("noise").toInt();
  int newConfirm = server.arg("confirm").toInt();
  int newWindow = server.arg("window").toInt();

  if (newNoise < 100 || newNoise > 30000) {
    server.send(400, "text/plain; charset=utf-8", "Sound sensitivity threshold must be 100..30000");
    return;
  }

  if (newConfirm < 1 || newConfirm > 10) {
    server.send(400, "text/plain; charset=utf-8", "Confirmations must be 1..10");
    return;
  }

  if (newWindow < 1 || newWindow > MAX_SOUND_WINDOW_SIZE) {
    server.send(400, "text/plain; charset=utf-8", "Smoothing must be 1.." + String(MAX_SOUND_WINDOW_SIZE));
    return;
  }

  noiseThreshold = newNoise;
  soundConfirmCount = newConfirm;
  soundWindowSize = newWindow;

  soundTriggerCount = 0;
  soundWindowIndex = 0;
  soundWindowFilled = false;
  for (int i = 0; i < MAX_SOUND_WINDOW_SIZE; i++) {
    soundWindow[i] = 0;
  }

  saveSettings();

  String msg = "Sound settings saved: threshold=" + String(noiseThreshold)
             + ", confirmations=" + String(soundConfirmCount)
             + ", smoothing=" + String(soundWindowSize);
  server.send(200, "text/plain; charset=utf-8", msg);
}

void handleList() {
  FileItem items[MAX_FILES];
  int count = collectSortedWavFiles(items, MAX_FILES);

  String json = "[";
  for (int i = 0; i < count; i++) {
    if (i > 0) json += ",";
    json += "{";
    json += "\"name\":\"" + jsonEscape(items[i].name) + "\",";
    json += "\"size\":" + String(items[i].size);
    json += "}";
  }
  json += "]";

  server.send(200, "application/json; charset=utf-8", json);
}

void handlePlay() {
  File file;
  String path;
  if (!openFileForReadByArg("name", file, path)) {
    server.send(404, "text/plain; charset=utf-8", "WAV file not found");
    return;
  }

  server.sendHeader("Accept-Ranges", "bytes");
  server.sendHeader("Cache-Control", "no-cache");
  server.streamFile(file, "audio/wav");
  file.close();
}

void handleDownload() {
  File file;
  String path;
  if (!openFileForReadByArg("name", file, path)) {
    server.send(404, "text/plain; charset=utf-8", "WAV file not found");
    return;
  }

  String onlyName = fileNameOnly(path);

  server.sendHeader("Content-Type", "audio/wav");
  server.sendHeader("Content-Disposition", "attachment; filename=\"" + onlyName + "\"");
  server.sendHeader("Content-Transfer-Encoding", "binary");
  server.sendHeader("Cache-Control", "no-cache");

  server.streamFile(file, "audio/wav");
  file.close();
}

void handleDelete() {
  if (!server.hasArg("name")) {
    server.send(400, "text/plain; charset=utf-8", "Missing file name");
    return;
  }

  String path = normalizePath(server.arg("name"));

  if (!isWavFileName(path)) {
    server.send(400, "text/plain; charset=utf-8", "Only WAV delete allowed");
    return;
  }

  if (!SD.exists(path)) {
    server.send(404, "text/plain; charset=utf-8", "File not found");
    return;
  }

  if (SD.remove(path)) {
    server.send(200, "text/plain; charset=utf-8", "Deleted");
  } else {
    server.send(500, "text/plain; charset=utf-8", "Delete failed");
  }
}

void handleDeleteAll() {
  File root = SD.open("/");
  if (!root) {
    server.send(500, "text/plain; charset=utf-8", "Root open failed");
    return;
  }

  int deletedCount = 0;
  int failedCount = 0;

  while (true) {
    File file = root.openNextFile();
    if (!file) break;

    if (!file.isDirectory()) {
      String path = normalizePath(String(file.name()));
      file.close();

      if (isWavFileName(path)) {
        if (SD.remove(path)) {
          deletedCount++;
        } else {
          failedCount++;
        }
      }
    } else {
      file.close();
    }
  }

  root.close();

  String msg = "Deleted WAV: " + String(deletedCount) + ", failed: " + String(failedCount);
  server.send(200, "text/plain; charset=utf-8", msg);
}

void handleResume() {
  server.send(200, "text/plain; charset=utf-8",
              "OK. Wi-Fi will be turned off, returning to monitor mode.");
  requestResumeMonitoring = true;
}

