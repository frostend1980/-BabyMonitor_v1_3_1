void startAccessPoint() {
  Serial.println();
  Serial.println("**************** WIFI MODE START ****************");
  WiFi.mode(WIFI_AP);
  bool ok = WiFi.softAP(apSSID, apPASS);

  if (ok) {
    Serial.printf("[WIFI] SSID: %s\n", apSSID);
    Serial.printf("[WIFI] PASS: %s\n", apPASS);
    Serial.print("[WIFI] IP: ");
    Serial.println(WiFi.softAPIP());
  } else {
    Serial.println("[WIFI] ERROR start failed");
  }

  apStartMillis = millis();
}

void startWebServer() {
  server.on("/", handleRoot);
  server.on("/status", handleStatus);
  server.on("/setrtc", handleSetRTC);
  server.on("/setap", handleSetAP);
  server.on("/clearap", handleClearAP);
  server.on("/setdaily", handleSetDaily);
  server.on("/cleardaily", handleClearDaily);
  server.on("/setaptimeout", handleSetAPTimeout);
  server.on("/setsound", handleSetSound);
  server.on("/list", handleList);
  server.on("/play", handlePlay);
  server.on("/download", handleDownload);
  server.on("/delete", handleDelete);
  server.on("/deleteall", handleDeleteAll);
  server.on("/resume", handleResume);

  server.begin();
  Serial.println("[WEB] server started");
}

void stopWebAndReturnToMonitoring() {
  Serial.println();
  Serial.println("**************** WIFI MODE STOP *****************");
  server.stop();
  WiFi.softAPdisconnect(true);
  WiFi.mode(WIFI_OFF);

  delay(500);

  requestResumeMonitoring = false;
  stopMonitoring = false;
  isRecording = false;
  touchTriggerCount = 0;
  soundTriggerCount = 0;
  soundWindowIndex = 0;
  soundWindowFilled = false;
  currentMode = MODE_MONITOR;

  Serial.println("[SYS] returned to MONITOR mode");
  printStatus();
}

void switchToWifiMode(const char* reason) {
  Serial.println();
  Serial.println(">>>>>>>>>>>>>>>> MODE SWITCH <<<<<<<<<<<<<<<<<<");
  Serial.printf("[SYS] switch to WIFI mode | reason=%s\n", reason);
  Serial.println(">>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>");

  stopMonitoring = true;

  if (isRecording) {
    delay(200);
  }

  currentMode = MODE_WIFI;
  startAccessPoint();
  startWebServer();
  printStatus();
}

void checkAPTimeoutAutoReturn() {
  if (currentMode != MODE_WIFI) return;
  if (apTimeoutMinutes < 1) return;

  unsigned long timeoutMs = (unsigned long)apTimeoutMinutes * 60000UL;
  if (millis() - apStartMillis >= timeoutMs) {
    Serial.println("[WIFI] AP timeout expired, returning to monitor");
    stopWebAndReturnToMonitoring();
  }
}

