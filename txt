// =====================================================
void setup() {
  Serial.begin(115200);
  delay(1000);

  Serial.println();
  Serial.println("================================================");
  Serial.println("      BABY MONITOR ESP32 + DS3231 v1.3.1");
  Serial.println("================================================");
  Serial.printf("[CFG] FW=%s\n", FW_VERSION);
  Serial.printf("[CFG] SAMPLE_RATE=%d\n", SAMPLE_RATE);
  Serial.printf("[CFG] RECORD_SECONDS=%d\n", RECORD_SECONDS);
  Serial.printf("[CFG] noiseThreshold=%d\n", noiseThreshold);
  Serial.printf("[CFG] touchThreshold=%d\n", touchThreshold);
  Serial.println("[CFG] RTC SDA=21 SCL=22");
  Serial.println("================================================");

  setupI2S();

  if (!setupSD()) {
    Serial.println("[SYS] SD init failed. HALT.");
    while (true) {
      delay(1000);
    }
  }

  rtcAvailable = setupRTC();
  loadSettings();

  Serial.println("[TOUCH] initial samples:");
  for (int i = 0; i < 10; i++) {
    int v = touchRead(TOUCH_PIN);
    Serial.printf("[TOUCH] sample %d = %d\n", i + 1, v);
    delay(200);
  }

  currentMode = MODE_MONITOR;
  stopMonitoring = false;
  isRecording = false;

  Serial.println("[SYS] monitoring started");
  printStatus();
}

// =====================================================
// LOOP
// =====================================================
void loop() {
  if (requestResumeMonitoring) {
    delay(300);
    stopWebAndReturnToMonitoring();
    return;
  }

  if (currentMode == MODE_WIFI) {
    server.handleClient();
    checkAPTimeoutAutoReturn();
    delay(2);
    return;
  }

  if (rtcAvailable && millis() - lastRtcPrint > 5000) {
    lastRtcPrint = millis();
    Serial.printf("[RTC] now=%s\n", formatDateTime(rtc.now()).c_str());
  }

  if (checkOneShotAPTrigger()) {
    switchToWifiMode("RTC one-shot schedule");
    return;
  }

  if (checkDailyAPTrigger()) {
    switchToWifiMode("RTC daily schedule");
    return;
  }

  if (millis() - lastTouchCheck >= touchCheckInterval) {
    lastTouchCheck = millis();

    if (checkTouchTriggered()) {
      touchTriggerCount = 0;
      switchToWifiMode("TOUCH");
      return;
    }
  }

  if (currentMode == MODE_MONITOR && !isRecording && !stopMonitoring) {
    int32_t level = getSmoothedAudioLevel();

    if (millis() - lastMicPrint > 500) {
      lastMicPrint = millis();
      Serial.printf("[MIC] smooth=%ld | threshold=%d | confirm=%d/%d | window=%d\n",
                    level, noiseThreshold, soundTriggerCount, soundConfirmCount, soundWindowSize);
    }

    if (level > noiseThreshold) {
      soundTriggerCount++;
      Serial.printf("[MIC] above threshold %d/%d | smooth=%ld\n",
                    soundTriggerCount, soundConfirmCount, level);
    } else {
      if (soundTriggerCount > 0) {
        Serial.println("[MIC] below threshold, sound counter reset");
      }
      soundTriggerCount = 0;
    }

    if (soundTriggerCount >= soundConfirmCount) {
      Serial.println();
      Serial.println("!!!!!!!!!!!!!!!! SOUND CONFIRMED !!!!!!!!!!!!!!!");
      Serial.printf("[MIC] stable trigger: smooth=%ld threshold=%d\n", level, noiseThreshold);
      Serial.println("!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!");
      Serial.println();

      soundTriggerCount = 0;

      currentFileName = makeFileName();
      bool ok = recordWav(currentFileName.c_str(), RECORD_SECONDS);

      if (ok) {
        Serial.printf("[MIC] saved: %s\n", currentFileName.c_str());
      } else {
        Serial.println("[MIC] record failed");
      }

      if (currentMode != MODE_WIFI) {
        delay(500);
        currentMode = MODE_MONITOR;
      }
    }
  }
}
